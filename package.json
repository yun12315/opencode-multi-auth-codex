{
  "name": "@guard22/opencode-multi-auth-codex",
  "version": "1.2.0",
  "description": "Multi-account OAuth rotation for OpenAI Codex with auto model discovery",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opencode-multi-auth": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "web": "node ./dist/cli.js web --port 3434 --host 127.0.0.1",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration",
    "test:web:headless": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/web-headless",
    "test:failure": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/failure",
    "test:stress": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/stress",
    "test:sandbox": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/sandbox",
    "test:soak:48h": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/soak",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@openauthjs/openauth": "^0.4.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.150"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.193",
    "@opencode-ai/sdk": "^1.0.193",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2"
  },
  "files": [
    "dist",
    "auto-login/auto_login.py",
    "auto-login/credentials.example.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guard22/opencode-multi-auth-codex"
  },
  "keywords": [
    "opencode",
    "openai",
    "codex",
    "oauth",
    "multi-account"
  ],
  "author": "a3fckx",
  "license": "MIT"
}
